PORT=5000
NODE_ENV=development

# ---- JWT ----
=======
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# ---- PostgreSQL ----
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=your_database_name

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/your_mongo_database_name

# ---- Correo (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email
SMTP_PASS=your_smtp_password
SMTP_FROM=VenditaApp <your_email>

# ---- Recuperación de contraseña ----
RESET_TOKEN_MIN=30

=======
# ---- CORS ----
FRONTEND_URL=http://localhost:3000
